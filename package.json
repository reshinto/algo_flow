    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.7.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.7",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react-vite": "^8.6.18",
